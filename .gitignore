# =============================================================================
# SLM-RL-Agents .gitignore
# =============================================================================

README_Old.md

scripts/generate_figures.py
scripts/aggregate_results.py

docs/

# Paper — never tracked
paper/

# Generated figures / visualizations (regenerated from results/all_results.json
# on demand via scripts/generate_figures.py — not tracked in git).
/figures/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.codex
*.claude
*.sixth

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Sphinx documentation
docs/_build/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Environment
.env
.venv
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# =============================================================================
# Project-specific
# =============================================================================

# Training outputs (models can be large)
outputs/
checkpoints/
logs/

# Data (may be large)
data/
!src/data/

# Weights & Biases
wandb/

# TensorBoard
runs/
tensorboard/

# Model caches
*.bin
*.safetensors
*.pt
*.pth

# But keep example configs
!configs/*.yaml

# Temporary files
*.tmp
*.temp
*.log

# Secrets
*.secret
credentials.json
api_keys.json
